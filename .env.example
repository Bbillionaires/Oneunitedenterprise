# ── CRM (Azoth) ──────────────────────────────────────────────────────
AZOTH_URL=http://localhost:3002
AZOTH_API_SECRET=
AZOTH_WORKSPACE_ID=
AZOTH_PIPELINE_ID=
AZOTH_DEFAULT_STAGE_ID=

# ── Stripe ───────────────────────────────────────────────────────────
# Get these from your Stripe dashboard > Developers > API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
# Add this after registering the webhook endpoint in Stripe dashboard
# Events to enable: payment_intent.succeeded, payment_intent.payment_failed
# Endpoint path: /api/payment/webhook
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# ── PayPal ───────────────────────────────────────────────────────────
# Get from https://developer.paypal.com/dashboard/applications
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# ── Square / Cash App Pay ────────────────────────────────────────────
# Get from https://developer.squareup.com/apps
NEXT_PUBLIC_SQUARE_APP_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=

# ── Admin authentication ─────────────────────────────────────────────
# Password for the /admin panel. Use a strong random string (16+ chars).
ADMIN_SECRET=change-me-to-a-strong-random-password

# ── Email notifications (Resend) ─────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=YOUR_RESEND_API_KEY
# Address that receives lead and payment notification emails
ADMIN_EMAIL=greenwood100inc@gmail.com
# Must match a verified sender domain in your Resend account
NOTIFICATION_FROM=noreply@oneunitedenterprise.com

# ── Site ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://oneunitedenterprise.vercel.app
